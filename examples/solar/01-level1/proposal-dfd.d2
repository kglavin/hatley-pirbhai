# Solar Local Stack — Level-1 DFD (PROPOSAL — pre-review)
#
# Draft visual of the proposed decomposition. Pre-naming, pre-locked —
# names will be revisited in the naming review after decomposition is
# accepted. Render: d2 proposal-dfd.d2 proposal-dfd.svg

direction: right

# ─── External terminators (level-0 boundary) ───
HM:   "Solar Inverters"            { shape: rectangle }
CM:   "Net Power Meter"            { shape: rectangle }
VX:   "Battery System"             { shape: rectangle }
USR:  "Owner"                      { shape: rectangle }
SMC:  "S-Miles Cloud\n(optional)" {
  shape: rectangle
  style.stroke-dash: 5
  style.opacity: 0.55
}

# ─── Internal bubbles (the proposed decomposition) ───
P1: "1. Acquire\nTelemetry" {
  shape: oval
  style.fill: "#cfe5ff"
}
P2: "2. Compute\nEnergy Balance" {
  shape: oval
  style.fill: "#7fbff5"
  style.bold: true
}
P3: "3. Dispatch\nCommands" {
  shape: oval
  style.fill: "#cfe5ff"
}
P4: "4. Serve UI" {
  shape: oval
  style.fill: "#cfe5ff"
}
P5: "5. Handle\nUser Input" {
  shape: oval
  style.fill: "#cfe5ff"
}
P6: "6. Cloud Forward\n(optional)" {
  shape: oval
  style.fill: "#e6f0ff"
  style.stroke-dash: 3
  style.opacity: 0.7
}

# ─── Boundary-crossing flows (the F1–F8 from level-0) ───
HM  -> P1: "F1: telemetry"
P3  -> HM: "F2: power-limit"
CM  -> P1: "F3: net grid power"
VX  -> P1: "F4: SoC, mode"
P3  -> VX: "F5: charge / grid setpoint"
USR -> P5: "F6: config, override"
P4  -> USR: "F7: dashboards, alerts"
P6  -> SMC: "F8: telemetry fwd" {
  style.stroke-dash: 5
  style.opacity: 0.6
}

# ─── Internal flows ───
P1 -> P2: "system_state"
P1 -> P4: "system_state"
P1 -> P6: "system_state" {
  style.stroke-dash: 3
  style.opacity: 0.6
}
P2 -> P3: "commands"
P2 -> P4: "event_alert"
P5 -> P2: "event_override"
P5 -> P1: "event_config" {
  style.opacity: 0.4
}
